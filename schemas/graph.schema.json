{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "graph.schema.json",
  "title": "Awesome Autonomous Biology generated graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "dataset_version", "methods", "clusters", "nodes", "edges"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "dataset_version": { "type": "string", "minLength": 1 },
    "methods": { "type": "object" },
    "clusters": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "label", "color", "categories", "category_count"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
          "categories": { "type": "array", "items": { "type": "string" } },
          "category_count": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "slug", "category", "cluster", "resource_type", "description", "url", "tags", "verification_status", "evidence_level", "closed_loop_stage", "last_updated", "layouts"],
        "properties": {
          "id": { "type": "string", "pattern": "^AAB-[0-9]{3}$" },
          "name": { "type": "string", "minLength": 1 },
          "slug": { "type": "string", "minLength": 1 },
          "category": { "type": "string" },
          "cluster": { "type": "object" },
          "resource_type": { "type": "string" },
          "description": { "type": "string" },
          "url": { "type": "string" },
          "github_url": { "type": ["string", "null"] },
          "paper_url": { "type": ["string", "null"] },
          "tags": { "type": "array", "items": { "type": "string" } },
          "verification_status": { "enum": ["verified", "review_pending", "archived"] },
          "evidence_level": { "enum": ["A", "B", "C"] },
          "closed_loop_stage": { "type": "array", "items": { "type": "string" } },
          "last_updated": { "type": ["string", "null"] },
          "layouts": {
            "type": "object",
            "required": ["ecosystem", "closedLoop", "timeline"]
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "target", "type", "inferred", "weight", "reasons", "provenance_status"],
        "properties": {
          "id": { "type": "string" },
          "source": { "type": "string" },
          "target": { "type": "string" },
          "type": { "enum": ["related_to", "shared_context"] },
          "inferred": { "type": "boolean" },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 },
          "reasons": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "provenance_status": { "type": "string" }
        }
      }
    }
  }
}
