---
import BaseLayout from "../../layouts/BaseLayout.astro";
import resources from "../../data/generated/all-resources.json";
import categories from "../../data/generated/categories.json";
const timelineData = resources.map((record) => ({ id: record.id, title: record.title, year: record.year, primary_category: record.primary_category, resource_class: record.resource_class, evidence: record.evidence.grade, status: record.curation.status }));
---
<BaseLayout title="Timeline & Trends - Awesome Autonomous Biology" current="timeline">
  <div class="shell">
    <header class="page-head"><div><p class="eyebrow">TIME SIGNAL - V0.2 - ASSERTED DATES ONLY</p><h1>Trace the field<br />without guessing years.</h1><p class="lede">All research records are counted; review-pending status is a grouping option, never hidden. Missing dates stay in a separate bucket.</p></div><div class="timeline-controls"><label for="timeline-group" class="eyebrow">Group color by</label><select id="timeline-group" data-timeline-group><option value="status">Curation status</option><option value="primary_category">Primary category</option><option value="resource_class">Resource class</option><option value="evidence">Evidence grade</option></select></div></header>
    <section class="panel panel-pad"><div class="legend" data-timeline-legend></div><div class="timeline-chart" data-timeline-chart aria-live="polite"></div></section>
    <p class="callout"><strong>Date not asserted</strong> is a deliberate bucket. A missing year is never estimated from repository activity or surrounding context. Candidate status is not factual confidence.</p>
    <script type="application/json" data-timeline-data set:html={JSON.stringify({records: timelineData, categories}).replace(/</g, "\u003c")} /><script src="../../scripts/timeline.ts"></script>
  </div>
</BaseLayout>
